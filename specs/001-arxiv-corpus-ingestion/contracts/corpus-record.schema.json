{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "corpus-record.schema.json",
  "title": "CorpusArticle",
  "description": "Uma linha de data/corpus.jsonl",
  "type": "object",
  "required": ["id", "title", "abstract", "authors", "categories", "date"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{4,5}$",
      "description": "ArXiv identifier without version suffix"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "abstract": {
      "type": "string",
      "minLength": 50
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z-]+\\.[A-Z]{2}$" }
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Publication date YYYY-MM-DD"
    }
  }
}
